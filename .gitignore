# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
.lighthouseci/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.playwright-mcp/
supabase/.temp/
scripts/reclassify-snapshot-*.json
scripts/reclassify-retry-snapshot-*.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.cursor/*.log

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# self-improving-agent — 工作记忆（会话/错误），本地生成即可
/memory/working/*.json

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# SVN 采集器本地配置（含密钥，不提交）
scripts/svn-collector.config.json
scripts/svn-collector-logs/

# 钉钉推送脚本（含敏感凭据，不提交实际使用的副本）
scripts/notify-register.py
